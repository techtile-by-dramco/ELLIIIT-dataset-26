---
interface Props {
  title: string;
  htmlPath: string;
  notebookPath: string;
}

const { title, htmlPath, notebookPath } = Astro.props;

function withBase(path: string): string {
  const base = import.meta.env.BASE_URL.endsWith("/")
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
  const normalizedPath = String(path).replace(/^\/+/, "");
  return `${base}${normalizedPath}`;
}

const htmlHref = withBase(htmlPath);
const notebookHref = withBase(notebookPath);
---

<div class="notebook-actions">
  <a href={htmlHref} target="_blank" rel="noreferrer">Open full notebook view</a>
  <a href={notebookHref} download>Download notebook</a>
</div>

<iframe
  title={title}
  src={htmlHref}
  loading="lazy"
  class="notebook-frame"
></iframe>

<style>
  .notebook-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin: 1rem 0;
  }

  .notebook-actions a {
    border: 1px solid var(--sl-color-hairline);
    border-radius: 999px;
    padding: 0.55rem 0.95rem;
    text-decoration: none;
    font-weight: 600;
  }

  .notebook-frame {
    width: 100%;
    min-height: 80vh;
    border: 1px solid var(--sl-color-hairline);
    border-radius: 1rem;
    background: white;
  }
</style>
